# ============================================================
#  GEO-TALENT AGENT — environment variables (EXAMPLE / PLACEHOLDERS)
#  Copy to .env.local (Next.js) and .env (Python scripts) and fill in.
#  NEVER commit the real .env / .env.local files.
# ============================================================

# ---- Site URL (used in auth redirect links) -----------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- LLM (provider-agnostic; Groq now, swappable to Claude/OpenAI later) ----
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile     # tool-use model; see console.groq.com/docs/models
LLM_MODEL_FAST=llama3-8b-8192         # small/cheap model for quick tasks
GROQ_API_KEY=                          # your Groq key
ANTHROPIC_API_KEY=                     # optional, for later
EMBEDDINGS_PROVIDER=none               # none | local  (RAG uses Postgres FTS until embeddings added)
SEARCH_API_KEY=                        # optional — Tavily / SerpApi, for flight-fare lookup

# ---- Supabase -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=                  # SERVER ONLY — never exposed to the browser

# ---- Registration domain ------------------------------------
ALLOWED_EMAIL_DOMAIN=moe.gov.my        # domain-restricted registration (@moe.gov.my OR admin_allowlist)

# ---- Geocoding / routing / email ----------------------------
GEOCODER_PROVIDER=nominatim            # nominatim | google | mapbox
ROUTING_PROVIDER=osrm                  # osrm | google
EMAIL_API_KEY=                         # Resend / Nodemailer

# ---- Security -----------------------------------------------
TOKEN_SIGNING_SECRET=                  # long random string for signed invitation tokens

# ---- Travel cost config (land tiers; flight/boat looked up at runtime) ----
RATE_ROAD_PER_KM_0_500=1.00
RATE_ROAD_PER_KM_OVER_500=0.90
RATE_ROUND_TRIP_MULTIPLIER=2           # confirm one-way vs round-trip with JPN finance
RATE_NIGHT_ALLOWANCE_MYR=0             # confirm per-night allowance with JPN finance
